{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 8,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "pulseaudio", "network"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true
  },

  "clock": {
    "format": "{:%H:%M}",
    "tooltip": false
  },

  "cpu": {
    "format": "  {usage}%",
    "interval": 3
  },

  "memory": {
    "format": "󰍛  {used:0.1f}G",
    "interval": 5
  },

  "network": {
    "format-wifi": "󰖩  {signalStrength}%",
    "format-ethernet": "󰈀  Connected",
    "format-disconnected": "󰖪  Offline",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰖁  0%",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    }
  }
}
